                <option value="">-- 選擇種類 --</option>
                {uniqueCategories.map(cat => <option key={cat} value={cat}>{cat}</option>)}
              </select>
            </div>
            
            <div className="flex-2 min-w-[240px]">
              <label className="text-xs font-bold text-slate-400 mb-1 block">食物 (資料庫)</label>
              <select 
                className="w-full border p-2 rounded outline-none focus:ring-1 focus:ring-emerald-200 bg-white text-sm"
                value={quickInput.foodName}
                onChange={e => setQuickInput({...quickInput, foodName: e.target.value})}
                disabled={!quickInput.category}
              >
                <option value="">-- 選擇食物 --</option>
                {filteredFoods.map(f => <option key={f.name} value={f.name}>{f.name}</option>)}
              </select>
            </div>

