            </div>
          </div>

          <div className="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8 bg-slate-50 p-6 rounded-2xl border border-slate-100 items-end text-xs">
            <div className="bg-white p-3 rounded-xl border shadow-sm">臨床狀況<select className="w-full font-bold mt-1 outline-none" value={intervention.condition} onChange={e=>setIntervention({...intervention, condition:e.target.value})}><option value="">-- 一般 --</option><option value="一般人">一般人</option><option value="DM">DM</option><option value="CKD">CKD</option></select></div>
            <div className="bg-white p-3 rounded-xl border shadow-sm">目標熱量<select className="w-full font-bold mt-1 outline-none text-indigo-700" value={intervention.targetCalories} onChange={e=>setIntervention({...intervention, targetCalories:e.target.value})}>{ (intervention.condition === 'DM' ? ['1200','1300','1400','1500','1600','1700','1800','2000','2200'] : (intervention.condition === 'CKD' ? ['1500','1650','1800','1950','2100','2250','2400','2550','2700'] : ['1200','1400','1500','1600','1800','2000'])).map(v=><option key={v} value={v}>{v}</option>) }</select></div>
