            <div className="flex items-center gap-2 text-indigo-500 font-bold p-3"><AlertCircle size={14} /> 比例隨下方份數調整</div>
          </div>

          <div className="overflow-x-auto border rounded-2xl shadow-inner mb-6">
            <table className="w-full text-[11px] border-collapse bg-white">
              <thead className="bg-slate-100 text-slate-600 font-bold uppercase">
                <tr><th className="p-3 border text-left sticky left-0 bg-slate-100">食物類別</th><th className="p-3 border text-center bg-indigo-100 text-indigo-700 w-24">總份數</th>{MEALS.map(m=><th key={m} className="p-3 border text-center">{m}</th>)}</tr>
              </thead>
              <tbody className="divide-y">
                {INTERVENTION_CATEGORIES.map(cat => (<tr key={cat} className="hover:bg-slate-50 transition-colors"><td className="p-3 border font-bold text-slate-700 sticky left-0 bg-white">{cat}</td><td className="p-3 border bg-indigo-50/30">
                      <input type="number" step="0.1" className="w-full text-center font-black text-indigo-600 bg-transparent outline-none border-b border-indigo-200" value={interventionPortions[cat].total} onChange={(e) => handleTotalChange(cat, e.target.value)} />
                    </td>{MEALS.map(m => (<td key={m} className="p-2 border"><input type="number" step="0.1" className="w-full text-center outline-none bg-transparent" value={interventionPortions[cat].meals[m]} onChange={(e) => { const val = parseFloat(e.target.value) || 0; setInterventionPortions(prev => { const next = { ...prev }; next[cat].meals[m] = val; next[cat].total = parseFloat(Object.values(next[cat].meals).reduce((s, v) => s + (parseFloat(v) || 0), 0).toFixed(1)); return next; }); }} /></td>))}</tr>))}</tbody>
            </table>
          </div>
          <div className="mt-8 border-t pt-6"><div className="flex items-center gap-2 mb-3 text-slate-700 font-bold"><FileText size={18} className="text-indigo-500" /><span>其他飲食建議 (衛教重點)</span></div><textarea className="w-full h-32 border rounded-xl p-4 text-sm focus:ring-1 focus:ring-indigo-300 outline-none bg-slate-50/30 shadow-inner" placeholder="記錄衛教建議內容..." value={intervention.otherAdvice} onChange={e=>setIntervention({...intervention, otherAdvice:e.target.value})} /></div>
        </div>

        {/* 四、監測與評量 */}
        <div className="flex items-center gap-2 mb-6 border-b-2 pb-2 text-emerald-700 border-emerald-200 mt-12"><Activity size={24}/><h2 className="text-xl font-bold">四、監測與評量</h2></div>
        <div className="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12 text-sm">
          <div className="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm border-t-4 border-t-emerald-400">
            <h4 className="font-bold text-emerald-800 mb-4 flex items-center gap-2"><CheckSquare size={18}/> 體位生理</h4>
            {['體重趨勢', 'BMI/IBW 變化', '肌肉量/體脂率'].map(c=>(<label key={c} className="flex items-center gap-3 p-2 hover:bg-emerald-50 rounded-lg text-sm transition-colors cursor-pointer"><input type="checkbox" className="w-4 h-4 rounded text-emerald-600" /> {c}</label>))}
          </div>
          <div className="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm border-t-4 border-t-emerald-400">
            <h4 className="font-bold text-emerald-800 mb-4 flex items-center gap-2"><CheckSquare size={18}/> 生化指標</h4>
            {['HbA1c/血糖達標', '腎功能 GFR/Cr', '電解質 Na/K/P'].map(c=>(<label key={c} className="flex items-center gap-3 p-2 hover:bg-emerald-50 rounded-lg text-sm transition-colors cursor-pointer"><input type="checkbox" className="w-4 h-4 rounded text-emerald-600" /> {c}</label>))}
          </div>
          <div className="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm border-t-4 border-t-emerald-400"><textarea className="w-full h-32 border rounded-xl p-3 text-xs focus:ring-1 focus:ring-emerald-200 outline-none shadow-inner" placeholder="記錄調整細節..."></textarea></div>
        </div>

        {/* 固定底欄 */}
        <div className="fixed bottom-6 right-6 flex items-center gap-4 bg-white/95 backdrop-blur-sm border border-slate-200 p-4 rounded-3xl shadow-2xl z-50">
          <div className="text-right px-4 border-r">
            <p className="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">當前評估 vs 介入目標</p>
            <p className="text-xl font-black text-indigo-700">
              {dietTotals.calories.toFixed(0)} <span className="text-sm text-slate-400 mx-1">/</span> {interventionResult.calories} <span className="text-xs text-slate-400 ml-1">kcal</span>
            </p>
          </div>
          <button className="bg-indigo-600 text-white px-8 py-3 rounded-2xl font-black hover:bg-indigo-700 shadow-lg flex items-center gap-2 transition-all active:scale-95"><Save size={20}/> 儲存紀錄</button>
        </div>
      </div>
    </div>
  );
};

export default App;
