                    <input type="checkbox" className="hidden" onChange={() => {
                      const next = patientInfo.exercise.types.includes(opt) ? patientInfo.exercise.types.filter(x => x !== opt) : [...patientInfo.exercise.types, opt];
                      setPatientInfo({...patientInfo, exercise: {...patientInfo.exercise, types: next}});
                    }} />{opt}
                  </label>
                ))}
              </div>
            </div>
          </div>
        </div>

        {/* --- 飲食紀錄區塊 --- */}
